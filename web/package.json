{
  "name": "deepseek-tui-web",
  "version": "1.1.0",
  "private": true,
  "description": "DeepSeek TUI — full web interface with auth, WebSocket streaming, settings, file uploads, and responsive design",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3100",
    "build": "next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public 2>/dev/null; true",
    "start": "next start -p 3100",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@tanstack/react-virtual": "^3.13.24",
    "better-auth": "^1.6.11",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-dropzone": "^14.3.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^15.6.0",
    "remark-gfm": "^4.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.0",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
